<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>

    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>
    <div class="w-full min-h-screen main bg-zinc-700">

        <div class="p-10 form">
            <form action="/create" method="post">
                <input class="block w-full px-5 py-2 text-white rounded-md bg-zinc-500" name="title" type="text"
                    placeholder="Title">
                <textarea class="block w-full px-5 py-2 mt-2 text-white rounded-lg resize-none bg-zinc-500"
                    name="textarea" placeholder="Write Your Task " id=""></textarea>
                <input class="p-2.5 mt-2 text-white bg-blue-600 rounded-md" type="submit" value="Create Task">
            </form>
        </div>

        <div class="flex flex-wrap gap-4 p-10 tasks">

            <% if(files.length>0){ %>

                <% files.forEach(function(val){ %>

                    <div class="px-3 py-4 rounded-md task bg-zinc-500 w-80">
                        <h1 class="text-3xl tracking-tighter text-white p-1">
                            <%= val %>
                        </h1>

                        <div class="flex justify-between rounded-xs">
                        <a class="text-blue-300 p-1" href="/file/<%= val %>">read more</a>
                        <a class="bg-blue-600 text-white flex rounded-md p-1.5 mt-2" href="/edit/<%= val %>">Edit</a>
                        </div>
                        
                    </div>

                    <% }) %>

                        <% } else { %>

                            <h2 class="text-2xl text-white">No Tasks Yet.</h2>

                            <% } %>



        </div>


    </div>
</body>

</html>