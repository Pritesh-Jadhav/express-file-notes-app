<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>

    <div class="w-full min-h-screen main bg-zinc-700 p-10 text-white">
        <a href="/" class="text-blue-300"><-- go back to home</a>
      
        <h1 class="text-4xl mt-5"><%= filename %></h1>

        <div class="p-5 form">
            <form action="/edit/<%= filename %>" method="post">
                <input class="block w-full px-5 py-2 text-white rounded-md bg-zinc-500" name="title" type="text"
                    placeholder="Edit Title" value="<%= filename %>">
                <textarea class="block w-full px-5 py-2 mt-2 text-white rounded-lg resize-none bg-zinc-500"
                    name="textarea" placeholder="Write Your Task " id=""><%= filedata %></textarea>
                <input class="p-2.5 mt-2 text-white bg-yellow-600 rounded-md" type="submit" value="Edit">
            </form>
        </div>
    </div>

</body>
</html>